    "Foreign direct investment, net inflows (% of GDP)": "FDI_GDP",
    "GDP per capita (constant 2015 US$)": "GDPC_2015",
    "Individuals using the Internet (% of population)": "Internet_Usage",
    "Industry (including construction), value added (% of GDP)": "Indus_GDP",
    "Services, value added (% of GDP)": "Serv_GDP"
  }
}
